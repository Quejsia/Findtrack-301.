rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global utility primitives
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking email verification helper (only verified users can write items and transact)
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validates item properties, checking types, boundaries, and formats
    function isValidItem(data) {
      return data.id is string && isValidId(data.id)
        && data.userId is string
        && (data.type == 'lost' || data.type == 'found')
        && data.title is string && data.title.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && (data.category in ['electronics', 'keys', 'wallet', 'documents', 'clothing', 'jewelry', 'bags', 'others'])
        && data.location is string && data.location.size() <= 200
        && (data.status == 'active' || data.status == 'resolved')
        && data.contactName is string && data.contactName.size() <= 100
        && data.contactInfo is string && data.contactInfo.size() <= 200
        && data.date is string && data.date.size() <= 100
        // FIX: was 500000 (500KB) which is far too large for a URL field and had no
        // other rate limiting attached to it — a plausible storage-cost abuse vector.
        && data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 500
        && data.get('verificationQuestion', '') is string
        && data.get('verificationQuestion', '').size() <= 500
        // FIX: 'securityQuestion' was allowed in the update field allowlist but was
        // never validated here, so it had no type or size limit at all.
        && data.get('securityQuestion', '') is string
        && data.get('securityQuestion', '').size() <= 500;
    }

    // Validates potential match parameters, enforcing score limits
    function isValidMatch(data) {
      return data.id is string && isValidId(data.id)
        && data.lostItemId is string && isValidId(data.lostItemId)
        && data.foundItemId is string && isValidId(data.foundItemId)
        && (data.confidenceScore is int || data.confidenceScore is float)
        && data.confidenceScore >= 0 && data.confidenceScore <= 100
        && data.matchReason is string && data.matchReason.size() <= 1000
        && (data.status == 'pending' || data.status == 'accepted' || data.status == 'rejected');
    }

    // Validates chat metadata structures
    function isValidChat(data) {
      return data.chatId is string && isValidId(data.chatId)
        && data.participants is list
        && data.participants.size() >= 2 && data.participants.size() <= 10
        && data.participants[0] is string
        && data.itemId is string && isValidId(data.itemId)
        && (data.get('lastMessage', '') is string && data.get('lastMessage', '').size() <= 2000);
    }

    // Validates individual message content
    function isValidMessage(data) {
      return data.senderId is string && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 2000;
    }

    // NEW: Validates claim properties — the original rules had no schema
    // validation on claims at all, unlike items/matches/chats.
    function isValidClaim(data) {
      return data.id is string && isValidId(data.id)
        && data.itemId is string && isValidId(data.itemId)
        && data.claimerId is string
        && data.finderId is string
        && (data.status == 'pending' || data.status == 'approved' || data.status == 'declined')
        && data.get('message', '') is string && data.get('message', '').size() <= 1000;
    }

    // --- Items Collection Rules ---
    match /items/{itemId} {
      // Allow all registered active users to view listings to find matches
      allow read, list: if isSignedIn();

      // Creating a new item
      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(itemId)
        && itemId == incoming().id
        && incoming().userId == request.auth.uid
        && isValidItem(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Updating item details
      allow update: if isSignedIn()
        && isEmailVerified()
        && isValidId(itemId)
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidItem(incoming())
        && (
          // Limit actual client modifications to expected functional fields
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'location', 'status', 'contactName', 'contactInfo', 'date', 'imageUrl', 'updatedAt', 'verificationQuestion', 'securityQuestion'])
        );

      // Deleting item entries
      allow delete: if isSignedIn()
        && isEmailVerified()
        && existing().userId == request.auth.uid;
    }

    // --- Private Item Secrets Rules ---
    match /itemSecrets/{itemId} {
      // Clients can NEVER read secret answers directly. Only verified via secure admin SDK.
      allow read: if false;

      // Allow creating secret verification answers
      // FIX: previously only checked incoming().userId == request.auth.uid, with no
      // check that this user actually owns the matching item. Since itemSecrets/{itemId}
      // is keyed by itemId, if the real owner hadn't created their secret doc yet, anyone
      // else could create it first and hijack the verification question for that item.
      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(itemId)
        && incoming().itemId == itemId
        && incoming().userId == request.auth.uid
        && get(/databases/$(database)/documents/items/$(itemId)).data.userId == request.auth.uid
        && incoming().securityAnswer is string
        && incoming().securityAnswer.size() <= 200;

      // Allow updating secret verification answers
      allow update: if isSignedIn()
        && isEmailVerified()
        && isValidId(itemId)
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().itemId == existing().itemId
        && get(/databases/$(database)/documents/items/$(itemId)).data.userId == request.auth.uid
        && incoming().securityAnswer is string
        && incoming().securityAnswer.size() <= 200;

      // Allow deleting secret verification answers
      allow delete: if isSignedIn()
        && isEmailVerified()
        && existing().userId == request.auth.uid;
    }

    // --- Claims Collection Rules ---
    match /claims/{claimId} {
      allow read: if isSignedIn()
        && isEmailVerified()
        && (
          existing().claimerId == request.auth.uid ||
          existing().finderId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(existing().itemId)).data.userId == request.auth.uid
        );

      // FIX: added isValidClaim() schema check and createdAt/updatedAt enforcement,
      // matching the rigor applied to items/matches/chats. Previously this only
      // checked claimerId, so a caller could write arbitrary extra fields/types.
      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(claimId)
        && claimId == incoming().id
        && incoming().claimerId == request.auth.uid
        && isValidClaim(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isEmailVerified()
        && isValidId(claimId)
        && (
          existing().finderId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(existing().itemId)).data.userId == request.auth.uid
        )
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        && (incoming().status == 'approved' || incoming().status == 'declined');
    }

    // --- Matches Collection Rules ---
    match /matches/{matchId} {
      allow list: if false;

      // Single match retrieval
      allow get: if isSignedIn()
        && isEmailVerified()
        && (
          get(/databases/$(database)/documents/items/$(existing().lostItemId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(existing().foundItemId)).data.userId == request.auth.uid
        );

      // Registering a potential matched connection
      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(matchId)
        && matchId == incoming().id
        && isValidMatch(incoming())
        && (
          get(/databases/$(database)/documents/items/$(incoming().lostItemId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(incoming().foundItemId)).data.userId == request.auth.uid
        )
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Accepting or rejecting a match
      allow update: if isSignedIn()
        && isEmailVerified()
        && isValidId(matchId)
        && (
          get(/databases/$(database)/documents/items/$(existing().lostItemId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(existing().foundItemId)).data.userId == request.auth.uid
        )
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidMatch(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);

      allow delete: if isSignedIn()
        && isEmailVerified()
        && (
          get(/databases/$(database)/documents/items/$(existing().lostItemId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/items/$(existing().foundItemId)).data.userId == request.auth.uid
        );
    }

    // --- Chats Collection Rules ---
    match /chats/{chatId} {
      allow read, list: if isSignedIn()
        && isEmailVerified()
        && request.auth.uid in existing().participants;

      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(chatId)
        && chatId == incoming().chatId
        && request.auth.uid in incoming().participants
        && isValidChat(incoming())
        && incoming().timestamp == request.time;

      allow update: if isSignedIn()
        && isEmailVerified()
        && isValidId(chatId)
        && request.auth.uid in existing().participants
        && incoming().chatId == existing().chatId
        && incoming().itemId == existing().itemId
        && incoming().participants == existing().participants
        && incoming().timestamp == request.time
        && isValidChat(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'timestamp']);
    }

    // --- Messages Subcollection Rules ---
    match /chats/{chatId}/messages/{messageId} {
      allow read, list: if isSignedIn()
        && isEmailVerified()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      allow create: if isSignedIn()
        && isEmailVerified()
        && isValidId(messageId)
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        && isValidMessage(incoming())
        && incoming().createdAt == request.time;
    }

    // --- Users Collection Rules ---
    // FIX: previously "allow read: if isSignedIn();" let ANY authenticated user
    // read ANY other user's full document. Now restricted to the owner. If your
    // UI needs to show other users' display names (e.g. on item cards or in chat),
    // move that public-safe subset of fields into a separate `publicProfiles/{userId}`
    // document that's readable by any signed-in user, and keep this `users` doc
    // for private data (email, phone, etc.) only.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write, update, delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
